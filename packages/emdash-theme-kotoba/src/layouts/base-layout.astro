---
import Header from "../components/header.astro";
import Footer from "../components/footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "且听书吟",
  description = "诗与梦想的远方",
} = Astro.props as Props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="generator" content="WordPress 3.2.1" />
  </head>
  <body class="home blog">
    <div class="site-layout">
      <Header />
      <main class="site-main">
        <slot />
        <Footer />
      </main>
      <ul class="site-fixed-widget">
        <li class="fixed-gotop">
          <button class="btn btn-light btn-icon btn-lg btn-rounded btn-gotop" type="button">Top</button>
        </li>
      </ul>
    </div>
  </body>
</html>

<style>
  :global(*) { box-sizing: border-box; }
  :global(body) {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: #f6f7fb;
    color: #111827;
  }
  .site-aside { border-bottom: 1px solid #e5e7eb; background: #fff; }
  .aside-inner { width: min(1100px, calc(100% - 32px)); margin: 0 auto; padding: 10px 0; }
  .site-menu ul { list-style: none; display: flex; gap: 14px; padding: 0; margin: 8px 0 0; }
  .site-menu a { color: #4b5563; text-decoration: none; font-size: 14px; }
  .site-submenu { display: flex; gap: 8px; margin-top: 10px; }
  .button-social { text-decoration: none; font-size: 12px; color: #374151; border: 1px solid #e5e7eb; padding: 4px 8px; border-radius: 999px; }
  .mobile-brand { display: none; }
  .container { width: min(1100px, calc(100% - 32px)); margin: 0 auto; }
  .site-main { padding: 16px 0 40px; }
  .footer { margin-top: 24px; color: #6b7280; font-size: 12px; }
  .footer .line { display: flex; gap: 8px; justify-content: center; }
  .footer a { color: inherit; text-decoration: none; }
  .site-fixed-widget { position: fixed; right: 16px; bottom: 16px; list-style: none; margin: 0; padding: 0; }
  .btn-gotop { border: 1px solid #d1d5db; background: #fff; border-radius: 999px; padding: 8px 12px; }
  :global(.page-shell) { width: min(1100px, calc(100% - 32px)); margin: 0 auto; }
  :global(.page-card) { background: #fff; border: 1px solid #e5e7eb; border-radius: 14px; padding: 18px 20px; }
  :global(.text-muted) { color: #6b7280; }
  :global(.post-list) { list-style: none; padding: 0; margin: 12px 0 0; display: grid; gap: 10px; }
  :global(.post-list a) { color: #111827; text-decoration: none; }
</style>
