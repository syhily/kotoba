---
import { queryTags } from "../../query/content.ts";
import { defaultPagination } from "../../options/defaults.ts";
import { paginate, readPage } from "../../query/pagination.ts";
import Pagination from "../../components/pagination.astro";
import BaseLayout from "../../layouts/base-layout.astro";

const tags = await queryTags();
const pageResult = paginate(tags, readPage(Astro.url), defaultPagination.tagsPerPage);
---

<BaseLayout title="标签 - 且听书吟" description="文章标签">
  <main class="page-shell">
    <div class="page-card">
      <h1>Tags</h1>
      <p>{pageResult.total} tags</p>
      <ul class="post-list">
        {pageResult.items.map((tag) => (
          <li><a href={`/tags/${tag.slug}`}>{tag.label}</a> ({tag.count})</li>
        ))}
      </ul>
      <Pagination page={pageResult.page} totalPages={pageResult.totalPages} basePath="/tags" />
    </div>
  </main>
</BaseLayout>
